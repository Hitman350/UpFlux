// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String?
}

model Website {
  id       String        @id @default(uuid())
  url      String
  userId   String
  ticks    WebsiteTick[] // One website will have many ticks (one to many relations)
  disabled Boolean       @default(false)
  paused   Boolean       @default(false)
}

model Validator {
  id             String        @id @default(uuid())
  publicKey      String
  location       String
  ipAddress      String
  pendingPayouts Int           @default(0)
  ticks          WebsiteTick[] // One validator will have many ticks (one to many relations)
}

model WebsiteTick {
  id        String @id @default(uuid())
  websiteId String

  validatorId String
  tick        Int
  createdAt   DateTime      @default(now())
  status      WebsiteStatus
  latency     Int
  website     Website       @relation(fields: [websiteId], references: [id]) // Foreign key relationship
  validator   Validator     @relation(fields: [validatorId], references: [id]) // Foreign key relationship
}

enum WebsiteStatus {
  Good
  Bad
}
